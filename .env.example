# Copy this file to `.env` and fill in your own values.
# Locally, if DATABASE_URL is not set, the app falls back to a SQLite file (local.db).

# Neon connection string (Neon dashboard -> your project -> Connect).
# IMPORTANT: use the POOLED string (hostname contains "-pooler"), not the direct one —
# it routes through Neon's built-in PgBouncer, which this app's engine settings expect.
# Either postgres:// or postgresql:// prefix is fine — the app normalizes it automatically.
# Replace every part below (user, password, host, db name) with your actual Neon values.
DATABASE_URL=postgresql://user:password@ep-example-12345-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require

# Flask session secret — set a long random string in production
SECRET_KEY=change-this-to-a-random-secret-string

# Optional, local dev server port
PORT=5000
